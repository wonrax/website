---
/* global astroHTML */

import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { ArrowDown } from "@/components/Icon";

type Props = {
  src: ImageMetadata | string;
  alt: string;
  width?: number | string;
  height?: number | string;
  quality?: number | string;
  format?: string;
  sizes?: string;
  widths?: number[];
  layout?: "constrained" | "fixed" | "full-width";
  fit?: string;
  position?: string;
  priority?: boolean;
  inferSize?: boolean;
} & Omit<astroHTML.JSX.ImgHTMLAttributes, "src" | "width" | "height" | "alt">;

const {
  src,
  alt,
  width,
  height,
  quality,
  format,
  sizes,
  widths,
  layout = "constrained",
  fit,
  position,
  priority,
  inferSize,
  loading = "lazy",
  decoding = "async",
  ...rest
} = Astro.props;

const parseDimension = (value: number | string | undefined) => {
  if (typeof value === "number") return value;
  if (typeof value !== "string") return undefined;

  const parsedValue = Number.parseInt(value, 10);
  return Number.isNaN(parsedValue) ? undefined : parsedValue;
};

const parsedWidth = parseDimension(width);
const parsedHeight = parseDimension(height);
const isRemoteImage =
  typeof src === "string" && /^https?:\/\//i.test(src.trim());
const shouldInferSize =
  inferSize ?? (isRemoteImage && (parsedWidth == null || parsedHeight == null));

const originalSrc = typeof src === "string" ? src : src.src;

if (
  typeof src === "string" &&
  !shouldInferSize &&
  (parsedWidth == null || parsedHeight == null)
) {
  throw new Error(
    "string image sources require width/height unless inferSize is enabled"
  );
}
---

{
  typeof src === "string" && shouldInferSize ? (
    <Image
      src={src}
      alt={alt}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      inferSize
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  ) : typeof src === "string" ? (
    <Image
      src={src}
      alt={alt}
      width={parsedWidth!}
      height={parsedHeight!}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  ) : parsedWidth != null && parsedHeight != null ? (
    <Image
      src={src}
      alt={alt}
      width={parsedWidth}
      height={parsedHeight}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  )
}
<div class="ui-meta image-caption">
  <div class="image-caption__text"><slot /></div>
  <a
    class="image-caption__download"
    href={originalSrc}
    aria-label={`Download image, ${alt}`}
  >
    <ArrowDown size={14} strokeWidth={2} />
  </a>
</div>

<style lang="scss">
  // Two-column layout: caption text on the left, download button on the right.
  // Center column eats space-between so they don't overlap.
  :global(.image-caption) {
    display: flex !important;
    flex-direction: row !important;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: nowrap;
  }

  :global(.image-caption__text) {
    flex: 1 1 auto;
    min-width: 0;
  }

  :global(.image-caption__download) {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0;
    background: transparent;
    color: var(--text-3);
    text-decoration: none;
    line-height: 0;
    transition: color var(--duration-fast) ease;

    &:hover {
      color: var(--accent);
    }
  }
</style>
