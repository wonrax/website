---
/* global astroHTML */

import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { ArrowDown } from "@/components/Icon";

type Props = {
  src: ImageMetadata | string;
  alt: string;
  width?: number | string;
  height?: number | string;
  quality?: number | string;
  format?: string;
  sizes?: string;
  widths?: number[];
  layout?: "constrained" | "fixed" | "full-width";
  fit?: string;
  position?: string;
  priority?: boolean;
  inferSize?: boolean;
} & Omit<astroHTML.JSX.ImgHTMLAttributes, "src" | "width" | "height" | "alt">;

const {
  src,
  alt,
  width,
  height,
  quality,
  format,
  sizes,
  widths,
  layout = "constrained",
  fit,
  position,
  priority,
  inferSize,
  loading = "lazy",
  decoding = "async",
  ...rest
} = Astro.props;

const parseDimension = (value: number | string | undefined) => {
  if (typeof value === "number") return value;
  if (typeof value !== "string") return undefined;

  const parsedValue = Number.parseInt(value, 10);
  return Number.isNaN(parsedValue) ? undefined : parsedValue;
};

const parsedWidth = parseDimension(width);
const parsedHeight = parseDimension(height);
const isRemoteImage =
  typeof src === "string" && /^https?:\/\//i.test(src.trim());
const shouldInferSize =
  inferSize ?? (isRemoteImage && (parsedWidth == null || parsedHeight == null));

const originalSrc = typeof src === "string" ? src : src.src;

if (
  typeof src === "string" &&
  !shouldInferSize &&
  (parsedWidth == null || parsedHeight == null)
) {
  throw new Error(
    "string image sources require width/height unless inferSize is enabled"
  );
}
---

{
  typeof src === "string" && shouldInferSize ? (
    <Image
      src={src}
      alt={alt}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      inferSize
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  ) : typeof src === "string" ? (
    <Image
      src={src}
      alt={alt}
      width={parsedWidth!}
      height={parsedHeight!}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  ) : parsedWidth != null && parsedHeight != null ? (
    <Image
      src={src}
      alt={alt}
      width={parsedWidth}
      height={parsedHeight}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      quality={quality}
      format={format}
      sizes={sizes}
      widths={widths}
      fit={fit}
      position={position}
      priority={priority}
      layout={layout}
      loading={loading}
      decoding={decoding}
      {...rest}
    />
  )
}
<div class="image-caption">
  <div>
    <slot />
  </div>
  <a
    class="rounded-button"
    href={originalSrc}
    aria-label={`Download image, ${alt}`}
  >
    <ArrowDown size={16} strokeWidth={2.5} />
  </a>
</div>

<style lang="scss">
  a.rounded-button {
    display: inline-block;
    padding: 6px;
    border-radius: 50%;
    background-color: var(--bg-additive-light);
    color: var(--color-white);
    text-decoration: none;
    margin-top: -4px;
    line-height: 0;
  }
</style>
