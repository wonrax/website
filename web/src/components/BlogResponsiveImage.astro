---
import type { ImageMetadata } from "astro";
import ResponsiveImage from "./ResponsiveImage.astro";

type Props = {
  src: ImageMetadata | string;
  alt: string;
  width?: number | string;
  height?: number | string;
  featuretype?: string;
  inferSize?: boolean;
};

const { src, alt, width, height, featuretype, inferSize, ...rest } =
  Astro.props;

void featuretype;
---

<ResponsiveImage
  src={src}
  alt={alt}
  width={width}
  height={height}
  quality={95}
  inferSize={inferSize}
  widths={[400, 800, 1200, 2048, 3840, 5760]}
  {...rest}><slot /></ResponsiveImage
>
