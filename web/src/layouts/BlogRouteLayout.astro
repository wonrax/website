---
import Layout from "./Layout.astro";
import NumberedNav from "@/components/NumberedNav.astro";
import { type Props as RootLayoutProps } from "./Layout.astro";

export type Props = RootLayoutProps;
---

<Layout seoProps={Astro.props.seoProps}>
  <slot name="head" slot="head" />
  <main class="narrow-shell blog-container">
    <NumberedNav active="blog" class="narrow-shell__nav" />
    <slot />
  </main>
</Layout>

<style lang="scss" is:global>
  // .blog-container hangs onto the class name so the existing post-content
  // selectors in BlogPostLayout.scss (e.g. `.blog-container h1`, code blocks)
  // keep matching. The narrow-shell does the layout work; this block adds the
  // post-page-specific reading affordances.
  .blog-container {
    font-size: var(--font-size-base);

    a {
      color: var(--text-body-link);

      &:visited {
        color: var(--text-body-link-visited);
      }
    }
  }
</style>
