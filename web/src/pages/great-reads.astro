---
import RootLayout from "@/layouts/Layout.astro";
import "@/layouts/layout.scss";
import GreatReadsFeed from "../components/GreatReadsFeedSolid.tsx";
import NumberedNav from "@/components/NumberedNav.astro";
import { JSDOM } from "jsdom";
import type { RSSItem } from "@/shared/parseRssFeed";
import type { HighlightItem } from "@/shared/parseHighlights";
import ToasterProvider from "@/components/ToasterProvider";

export function parseFeedServer(xml: string): RSSItem[] {
  const doc = new JSDOM(xml, {
    contentType: "text/xml",
  }).window.document;

  const items = Array.from(doc.querySelectorAll("item"));
  return items.map((item) => ({
    title: item.querySelector("title")?.textContent ?? undefined,
    link: item.querySelector("link")?.textContent ?? undefined,
    pubDate: item.querySelector("pubDate")?.textContent ?? undefined,
  }));
}

let highlights: HighlightItem[] = [];
let initialItems: RSSItem[] = [];

try {
  // Bootstrap from the public RSS feed so the page renders without the API.
  const FEED_URL = "https://bg.raindrop.io/rss/public/55948413";
  const rssRes = await fetch(FEED_URL);
  const xml = await rssRes.text();
  initialItems = parseFeedServer(xml);
} catch (error) {
  console.error("Failed to fetch RSS feed:", error);
  initialItems = [];
}
---

<RootLayout
  seoProps={{
    title: "bookmarks",
    description: "articles i've saved, with the passages i highlighted",
  }}
>
  <ToasterProvider client:only="solid-js" />
  <main class="narrow-shell">
    <NumberedNav active="bookmarks" class="narrow-shell__nav" />
    <header class="narrow-shell__hero">
      <h1 class="narrow-shell__title">great reads.</h1>
      <p class="narrow-shell__lede">
        articles i saved, with the passages i highlighted
      </p>
    </header>
    <GreatReadsFeed
      initialItems={initialItems}
      initialHighlights={highlights}
      client:idle
    />
  </main>
</RootLayout>
