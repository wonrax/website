---
import RootLayout from "@/layouts/Layout.astro";
import "@/layouts/layout.scss";
import RecommenderFeed from "@/components/RecommenderFeedSolid.tsx";
import ToasterProvider from "@/components/ToasterProvider";
import NumberedNav from "@/components/NumberedNav.astro";
---

<RootLayout
  seoProps={{
    title: "feed",
    description: "personalized article recommendations",
    noindex: true,
  }}
>
  <ToasterProvider client:only="solid-js" />
  <main class="narrow-shell">
    <NumberedNav class="narrow-shell__nav" />
    <header class="narrow-shell__hero">
      <h1 class="narrow-shell__title">the feed.</h1>
      <p class="narrow-shell__lede">
        lobsters and hacker news items, ranked by similarity to what you've
        already read.
      </p>
    </header>
    <RecommenderFeed client:only="solid-js" />
  </main>
</RootLayout>
