---
import RootLayout from "@/layouts/Layout.astro";
import GitHub from "@/components/Logo/GitHubSolid";
import config from "@/config";
---

<RootLayout
  seoProps={{
    title: "Login to wrx.sh",
    description: "Login page to wrx.sh",
  }}
>
  <main>
    <h1>Login to wrx.sh</h1>
    <a
      class="ui-button ui-button--primary ui-button--lg"
      href={`${config.API_URL}/login/github?return_to=/settings`}
    >
      <GitHub width={24} />
      Continue with GitHub
    </a>
  </main>
</RootLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100vh;
    padding-top: 128px;
    box-sizing: border-box;
  }

  h1 {
    margin-bottom: var(--space-12);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-heading);
  }
</style>
