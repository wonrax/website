---
import RootLayout from "@/layouts/Layout.astro";
import GitHub from "@/components/Logo/GitHubSolid";
import config from "@/config";
---

<RootLayout
  seoProps={{
    title: "Login to wrx.sh",
    description: "Login page to wrx.sh",
  }}
>
  <main>
    <h1>Login to wrx.sh</h1>
    <a href={`${config.API_URL}/login/github?return_to=/settings`}>
      <GitHub width={24} />
      Continue with GitHub
    </a>
  </main>
</RootLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100vh;
    padding-top: 128px;
    box-sizing: border-box;
  }

  h1 {
    margin-bottom: var(--space-12);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-heading);
  }

  a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    padding: var(--space-6) var(--space-14);
    border: none;
    border-radius: var(--radius-xl);
    background-color: var(--text-body-heavy);
    color: var(--bg-color);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
  }

  a:hover {
    opacity: 0.9;
  }

  a:focus {
    outline: none;
    box-shadow: 0 0 0 3px var(--accent-color);
  }
</style>
