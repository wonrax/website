---
import RootLayout from "@/layouts/Layout.astro";
import "@/layouts/layout.scss";
import { getCollection, type CollectionEntry } from "astro:content";
import type { GetStaticPathsResult } from "astro";
import BlogArticleList from "@/components/BlogArticleList.astro";
import NumberedNav from "@/components/NumberedNav.astro";

type BlogEntry = CollectionEntry<"blog">;

const allPosts = (await getCollection("blog")) as BlogEntry[];

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  const allPosts = (await getCollection("blog")) as BlogEntry[];
  const tag = new Set<string>();
  for (const post of allPosts) {
    for (const t of post.data.tags) {
      tag.add(t);
    }
  }

  return Array.from(tag.values()).map((t) => ({
    params: {
      slug: t,
    },
  }));
}

const { slug } = Astro.params;
---

<RootLayout
  seoProps={{
    title: `#${slug}`,
    description: `posts tagged #${slug}`,
  }}
>
  <main class="narrow-shell">
    <NumberedNav active="blog" class="narrow-shell__nav" />
    <header class="narrow-shell__hero">
      <h1 class="narrow-shell__title">#{slug}</h1>
      <p class="narrow-shell__lede">
        every post tagged with <code>#{slug}</code>, newest first.
      </p>
    </header>
    <BlogArticleList
      posts={allPosts.filter((post: BlogEntry) => {
        return (
          slug &&
          post.data.tags.includes(String(slug)) &&
          (process.env.NODE_ENV !== "production" ||
            (!post.data.isDraft && !post.data.hidden))
        );
      })}
      allPosts={allPosts}
      tag={slug}
    />
  </main>
</RootLayout>
