---
import BlogRouteLayout from "@/layouts/BlogRouteLayout.astro";
import "@/layouts/layout.scss";
import BlogArticleList from "@/components/BlogArticleList.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type BlogEntry = CollectionEntry<"blog">;

const allPosts = (await getCollection("blog")) as BlogEntry[];
---

<BlogRouteLayout seoProps={{ title: "blog index", description: "blog index" }}>
  <BlogArticleList
    posts={allPosts.filter((post: BlogEntry) => {
      return (
        process.env.NODE_ENV !== "production" ||
        (post.data.isDraft !== true && post.data.hidden !== true)
      );
    })}
    allPosts={allPosts}
  />
</BlogRouteLayout>
