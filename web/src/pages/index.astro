---
import RootLayout from "../layouts/Layout.astro";
import "@/layouts/layout.scss";
import CurrentlyPlaying from "./_currently-playing";
---

<RootLayout seoProps={{ title: "homepage", description: "wrx.sh homepage" }}>
  <main class="centered-layout">
    <section class="home-main">
      <div class="profile-summary">
        <img
          class="home-main__pixel-icon only-light-mode"
          width="48"
          alt=""
          src="https://res.cloudinary.com/dmdgv6qrg/image/upload/v1726327480/hhai.dev%20blog/internet-person.ico"
        />
        <h3>wonrax</h3>
        <h4 class="job-title">Software Engineer</h4>
        <p class="profile-description">
          I design everything from software systems to the user interface. I
          code religiously, take photos and practice witchcraft. I love
          open-source.
        </p>
        <div class="links-section">
          <a href="/blog" class="link">Blog</a>
          <a
            class="link instagram"
            href="https://www.instagram.com/wnrax/"
            target="_blank"
            rel="noopener noreferrer">Photos</a
          >
        </div>
        <div class="home-main__email">
          <img
            class="home-main__email-icon only-light-mode"
            width="32"
            height="32"
            alt=""
            src="https://res.cloudinary.com/dmdgv6qrg/image/upload/v1726327480/hhai.dev%20blog/email.ico"
          />
          <p><strong>hi</strong> (at) <i>this domain</i></p>
        </div>
      </div>
      <div class="projects-section">
        <img
          class="home-main__pixel-icon only-light-mode"
          width="48"
          alt=""
          src="https://res.cloudinary.com/dmdgv6qrg/image/upload/v1726327480/hhai.dev%20blog/projects.ico"
        />
        <h3>Projects</h3>
        <div class="project-entry">
          <h4>2021 — Vietnamese sentiment analysis</h4>
          <p class="project-description">
            In my graduation thesis, I developed a BERT-based model to predict
            sentiment in Vietnamese texts.{" "}
            <a
              href="https://huggingface.co/wonrax/phobert-base-vietnamese-sentiment"
              target="_blank"
              rel="noopener noreferrer"
              class="link">Published on Hugging Face</a
            >, it has garnered 800,000+ downloads.
          </p>
        </div>
        <div class="project-entry">
          <h4>2021 — Mybk Mobile Android app</h4>
          <p class="project-description">
            The app effortlessly fetches class schedules and vital info, built
            with local first in mind so it works even if you're offline,{" "}
            <a
              href="https://play.google.com/store/apps/details?id=com.wonrax.mybk"
              target="_blank"
              rel="noopener noreferrer"
              class="link"
            >
              published on the Google Play Store
            </a>{" "}
            and has over 3,000 monthly active users.{" "}
            <a
              href="https://github.com/wonrax/mybk-mobile"
              target="_blank"
              rel="noopener noreferrer"
              class="link"
            >
              Open sourced on GitHub.
            </a>
          </p>
        </div>
      </div>
    </section>
    <section class="home-main__now-playing">
      <CurrentlyPlaying client:only="solid-js" />
    </section>
  </main>
</RootLayout>

<style lang="scss">
  :global(body) {
    background-color: rgba(255, 255, 255, 0.95);

    @media (prefers-color-scheme: dark) {
      background-color: unset;
    }
  }

  :global(html) {
    background-image: url("https://res.cloudinary.com/dmdgv6qrg/image/upload/v1726328435/hhai.dev%20blog/internet-pc.ico");
    background-repeat: no-repeat;
    background-position: 120% 120%;
    background-size: 712px;
    image-rendering: pixelated;

    @media (max-width: 1100px) {
      background-size: 612px;
      background-position: 130% 130%;
    }

    @media (max-width: 768px) {
      background-image: none;
    }

    @media (prefers-color-scheme: dark) {
      background-image: none;
    }
  }

  .only-light-mode {
    display: none;

    @media (prefers-color-scheme: light) {
      display: block;
    }
  }

  .home-main {
    display: flex;
    flex-direction: row;
    gap: 32px;

    p {
      margin: 16px 0;
      letter-spacing: 0;
    }

    &__pixel-icon {
      image-rendering: pixelated;
      margin-bottom: var(--space-4);
    }

    &__email {
      margin-top: var(--space-6);
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
    }

    &__email-icon {
      image-rendering: pixelated;
    }

    &__now-playing {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      justify-content: end;
    }

    .profile-summary {
      max-width: 295px;

      h3 {
        font-size: 18px;
      }

      .job-title {
        color: var(--text-body-medium);
        margin-top: 0;
      }

      .profile-description {
        color: var(--text-body-medium);
        line-height: 1.5em;
      }
    }

    .links-section {
      display: flex;
      flex-direction: row;
      gap: 16px;
    }

    .link {
      color: var(--text-body-link);
      text-decoration: underline;
    }

    .instagram {
      background-image: var(--accent-gradient);
      color: transparent;
      background-clip: text;
      text-decoration: underline;
      position: relative;

      /* Underline */
      &::before {
        content: "";
        position: absolute;
        top: 100%;
        width: 100%;
        left: 0;
        height: 1.5px;
        margin-top: -2.5px;
        background: var(--accent-gradient);
      }
    }

    h3,
    h4 {
      font-weight: var(--font-weight-medium);
      margin: 8px 0;
      margin-top: 0;
      color: var(--text-body-heavy);
    }

    .projects-section {
      flex-grow: 1;

      h3 {
        margin-bottom: 24px;
      }

      .project-entry {
        margin-bottom: 32px;

        h4 {
          margin-bottom: -6px;
        }

        .project-description {
          color: var(--text-body-medium);
          line-height: 1.5em;
        }
      }
    }

    @media (max-width: 768px) {
      flex-direction: column;

      .profile-summary {
        max-width: 100%;
        width: 100%;
      }

      .projects-section {
        max-width: 100%;
        width: 100%;
      }
    }
  }
</style>
