---
import RootLayout from "../layouts/Layout.astro";
import "@/layouts/layout.scss";
import CurrentlyPlaying from "./_currently-playing";
import NumberedNav from "@/components/NumberedNav.astro";
import HomeRecentBookmarks from "@/components/HomeRecentBookmarks.tsx";
import { getCollection } from "astro:content";
import { getPostSlug } from "@/shared/blog";

type Project = {
  name: string;
  role: string;
  description: string;
  meta: string;
  link: string;
  linkHref: string;
};

const allPosts = await getCollection("blog");
// Recent writing on the home page always excludes drafts/hidden, even in dev,
// since this is a public-facing slot.
const publishedPosts = allPosts.filter(
  (p) => p.data.isDraft !== true && p.data.hidden !== true
);
const recentPosts = [...publishedPosts]
  .sort(
    (a, b) =>
      new Date(b.data.published).getTime() -
      new Date(a.data.published).getTime()
  )
  .slice(0, 3);

function formatPostDate(raw: string): string {
  const d = new Date(raw);
  const day = String(d.getDate()).padStart(2, "0");
  const monthShort = d.toLocaleString("en-US", { month: "short" });
  return `${day} ${monthShort}`;
}

const projects: Project[] = [
  {
    name: "diffui",
    role: "creator · in progress",
    description:
      "Native GUI for browsing revisions and diffs across git and jj repos. Built with iced, syntax-highlighted via tree-sitter. The tool I wanted while reviewing my own history.",
    meta: "2026 · rust · iced · jj",
    link: "github.com/wonrax/diffui",
    linkHref: "https://github.com/wonrax/diffui",
  },
  {
    name: "vietnamese sentiment",
    role: "graduation thesis · published",
    description:
      "BERT-based model that predicts sentiment in Vietnamese texts. Built for my graduation thesis, kept alive as a tiny public artifact with 800k+ downloads on Hugging Face.",
    meta: "2021 · python · pytorch · phobert",
    link: "huggingface.co/wonrax/phobert-…",
    linkHref: "https://huggingface.co/wonrax/phobert-base-vietnamese-sentiment",
  },
  {
    name: "mybk mobile",
    role: "creator · open source",
    description:
      "Android app that fetches class schedules and vital info — local-first so it still works offline. Listed on Google Play with 3k+ monthly active users; source on GitHub.",
    meta: "2021 · android · kotlin",
    link: "github.com/wonrax/mybk-mobile",
    linkHref: "https://github.com/wonrax/mybk-mobile",
  },
];
---

<RootLayout seoProps={{ title: "wonrax", description: "wrx.sh homepage" }}>
  <main class="narrow-shell home">
    <NumberedNav active="home" class="narrow-shell__nav" />

    <header class="home__hero">
      <h1 class="home__name">wonrax</h1>
      <p class="home__bio">
        I design everything from software systems to the user interface. I code
        religiously, take photos and <span class="home__bio-muted"
          >practice witchcraft</span
        >. I love open-source.
      </p>
      <ul class="ui-meta home__socials">
        <li>
          <a
            class="ui-link"
            href="https://github.com/wonrax"
            target="_blank"
            rel="noopener noreferrer">github</a
          >
        </li>
        <li>
          <a
            class="ui-link"
            href="https://www.instagram.com/wnrax/"
            target="_blank"
            rel="noopener noreferrer">photography</a
          >
        </li>
        <li>email: <strong>hi</strong> at <strong>this domain</strong></li>
      </ul>
    </header>

    <section class="home__section home__projects">
      <header class="ui-kicker home__section-head">
        <span class="home__section-label">─ projects</span>
        <span class="home__section-count">{projects.length} live</span>
      </header>
      <ul class="home__project-list">
        {
          projects.map((p) => (
            <li class="home__project">
              <div class="home__project-head">
                <h2 class="home__project-name">
                  <a
                    class="ui-link ui-link--title"
                    href={p.linkHref}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {p.name}
                  </a>
                </h2>
                <p class="ui-meta home__project-role">{p.role}</p>
              </div>
              <p class="home__project-desc">{p.description}</p>
              <p class="ui-meta home__project-meta">
                <span>{p.meta}</span>
                <span class="home__project-sep" aria-hidden="true">
                  ·
                </span>
                <a
                  class="ui-link ui-link--muted"
                  href={p.linkHref}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {p.link}
                </a>
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="home__section home__secondary">
      <div class="home__secondary-col">
        <header class="ui-kicker home__recent-head">
          <span class="home__recent-label">─ recent writing</span>
          <a class="ui-link ui-link--muted home__recent-link" href="/blog">
            {"all ->"}
          </a>
        </header>
        <ul class="home__recent-list">
          {
            recentPosts.length === 0 ? (
              <li class="home__recent-row home__recent-row--empty">
                <span class="home__recent-empty">no posts yet.</span>
              </li>
            ) : (
              recentPosts.map((post) => (
                <li class="home__recent-row">
                  <span class="ui-meta home__recent-date">
                    {formatPostDate(post.data.published)}
                  </span>
                  <a
                    class="ui-link ui-link--title"
                    href={`/blog/${getPostSlug(post)}`}
                  >
                    {post.data.title}
                  </a>
                </li>
              ))
            )
          }
        </ul>
      </div>
      <div class="home__secondary-col">
        <header class="ui-kicker home__recent-head">
          <span class="home__recent-label">─ recent bookmarks</span>
          <a
            class="ui-link ui-link--muted home__recent-link"
            href="/great-reads"
          >
            {"all ->"}
          </a>
        </header>
        <HomeRecentBookmarks client:only="solid-js" />
      </div>
    </section>

    <section class="home__section home__now">
      <header class="ui-kicker home__section-head">
        <span class="home__section-label">─ now playing</span>
      </header>
      <CurrentlyPlaying client:only="solid-js" />
    </section>
  </main>
</RootLayout>

<style lang="scss">
  .home__hero {
    margin-bottom: var(--space-24);
  }

  .home__name {
    font-family: var(--font-display);
    font-size: var(--font-size-4xl);
    line-height: 1.1;
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--text-1);

    @media (max-width: 600px) {
      font-size: var(--font-size-3xl);
    }
  }

  .home__bio {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    line-height: 1.65;
    color: var(--text-1);
    margin: var(--space-7) 0 0;
    max-width: 56ch;
  }

  .home__bio-muted {
    color: var(--text-2);
  }

  .home__socials {
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-9);
  }

  .home__section {
    margin-top: var(--space-16);
    padding-top: var(--space-10);
    border-top: 1px solid var(--rule-strong);
  }

  .home__section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .home__section-count {
    letter-spacing: var(--tracking-loose);
    text-transform: none;
  }

  // First project's own border-top + the "─ projects" label already provide
  // separation; drop the section's outer top rule to avoid double-stripe.
  .home__projects {
    border-top: 0;
  }

  .home__project-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .home__project {
    display: grid;
    grid-template-columns: 160px 1fr;
    column-gap: var(--space-12);
    row-gap: var(--space-2);
    align-items: baseline;
    padding: var(--space-9) 0;
    border-top: 1px solid var(--rule);
    color: var(--text-1);
    list-style: none;
  }

  .home__project-head {
    grid-column: 1;
    grid-row: 1 / span 2;
  }

  .home__project-name {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.2;
    font-weight: var(--font-weight-medium);
    color: var(--text-1);
    letter-spacing: var(--tracking-snug);
    margin: 0;
  }

  .home__project-role {
    line-height: 1.5;
    margin: var(--space-2) 0 0;
  }

  .home__project-desc {
    grid-column: 2;
    grid-row: 1;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-size-md);
    line-height: 1.55;
    color: var(--text-1);
  }

  .home__project-meta {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: var(--space-3);
    row-gap: var(--space-1);
    line-height: 1.5;
    margin: var(--space-1) 0 0;
  }

  .home__project-sep {
    color: var(--fg-quiet);
  }

  @media (max-width: 600px) {
    .home__project {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: var(--space-4);
    }
    .home__project-head {
      grid-column: 1;
      grid-row: 1;
    }
    .home__project-desc {
      grid-column: 1;
      grid-row: 2;
    }
    .home__project-meta {
      grid-column: 1;
      grid-row: 3;
    }
  }

  // Drops the inherited `.home__section` top margin since the recent-head
  // already provides separation via its own border-top rule.
  .home__secondary {
    margin-top: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-16);
    row-gap: var(--space-12);

    @media (max-width: 600px) {
      grid-template-columns: 1fr;
    }
  }

  .home__recent-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .home__recent-label {
    color: var(--text-3);
  }

  // Resets the inherited uppercase/tracking-wider from `.home__recent-head`
  // — the recent-link reads as normal-case meta despite sitting in a caps row.
  .home__recent-link {
    letter-spacing: var(--tracking-loose);
    text-transform: none;
  }

  :global(.home__recent-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  :global(.home__recent-row) {
    display: grid;
    grid-template-columns: 52px 1fr;
    column-gap: var(--space-6);
    padding: var(--space-3) 0;
    align-items: baseline;
    border-bottom: 1px dashed var(--rule);

    &:last-child {
      border-bottom: 0;
    }
  }

  :global(.home__recent-row--empty),
  :global(.home__recent-row--skeleton) {
    color: var(--text-3);
  }

  :global(.home__recent-date) {
    white-space: nowrap;
  }

  :global(.home__recent-empty) {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--text-3);
  }

  // Placeholder bar keeps row height stable while the bookmarks API loads.
  :global(.home__recent-skeleton-title) {
    display: block;
    width: 80%;
    height: 10px;
    background: var(--bg-additive-light);
  }

  .home__now :global(.currently-playing p) {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--text-2);
    letter-spacing: var(--tracking-normal);
    margin: var(--space-3) 0;
  }

  .home__now :global(.currently-playing strong) {
    color: var(--text-1);
    font-weight: var(--font-weight-medium);
  }
</style>

<!--
  Global hide-when-empty rule for the "now playing" section. Lives in an
  is:global block because Astro doesn't compile `:global()` inside `:has()`
  (it leaves the literal `:global(...)` text in the output, which is invalid
  CSS and gets dropped by the browser). The CurrentlyPlaying widget is
  `client:only` and renders null when nothing is playing — so the section
  has no `.currently-playing` descendant unless a track is live.
-->
<style is:global>
  .home__now:not(:has(.currently-playing)) {
    display: none;
  }
</style>
